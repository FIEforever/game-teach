{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/games/(.*)", "destination": "/server/uploads/games/$1/index.html" },
    { "source": "/static/(.*)", "destination": "/web/static/$1" },
    { "source": "/(.*)", "destination": "/web/index.html" }
  ]
}
