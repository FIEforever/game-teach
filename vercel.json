{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/play/(.*)", "dest": "/server/uploads/games/$1/index.html" },
    { "src": "/static/(.*)", "dest": "/web/static/$1" },
    { "src": "/(.*)", "dest": "/web/index.html" }
  ]
}
